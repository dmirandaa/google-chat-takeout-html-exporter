# Google Chat Takeout HTML Exporter Configuration

# Owner's email (identifies who is the sender/owner in conversations)
OWNER_EMAIL=Google@gmail.com

# Timezone for date/time display (IANA timezone format)
# Examples: America/New_York, Europe/London, America/Sao_Paulo, Asia/Tokyo, UTC
TIMEZONE=America/Sao_Paulo

# Locale for date formatting (language and region)
# Examples: en-US, pt-BR, de-DE, fr-FR, es-ES
LOCALE=pt-BR

# Output directory for generated HTML files
OUTPUT_DIR=./output

# Path to the Google Chat data (usually the Groups folder)
DATA_SOURCE_PATH=/home/user/google-chat-takeout-html-exporter/Google Chat/Groups

# User data source path
USER_DATA_PATH=/home/user/google-chat-takeout-html-exporter/Google Chat/Users

# Pagination: Maximum messages per HTML file (0 = no pagination, all in one file)
# Recommended: 0 for < 5k messages, 1000 for 5k-20k, 500 for 20k+
MESSAGES_PER_PAGE=500
